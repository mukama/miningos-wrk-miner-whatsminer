{
  "name": "@tetherto/miningos-wrk-miner-whatsminer",
  "version": "0.0.1",
  "description": "MiningOS Worker Miner Whatsminer",
  "keywords": [
    "tether"
  ],
  "author": "Tether",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tetherto/miningos-wrk-miner-whatsminer.git"
  },
  "engine": {
    "node": ">=20.0"
  },
  "scripts": {
    "lint": "standard",
    "lint:fix": "standard --fix",
    "test": "npm run lint && npm run test:unit && npm run test:integration",
    "test:unit": "brittle tests/unit/*.js",
    "test:integration": "NODE_ENV=test brittle ./tests/miner.test.js",
    "test:integration:protocols": "NODE_ENV=test brittle ./tests/integration/protocols-*.test.js",
    "test:integration:v2": "NODE_ENV=test brittle ./tests/integration/protocols-v2.test.js",
    "test:integration:v3": "NODE_ENV=test brittle ./tests/integration/protocols-v3.test.js",
    "test:integration:compare": "NODE_ENV=test brittle ./tests/integration/protocols-compare.test.js",
    "test:integration:all": "npm run test:integration && npm run test:integration:protocols",
    "test:coverage": "brittle --coverage tests/unit/*.js",
    "dev": "node worker.js --wtype wrk-miner-rack-m56s --env production --rack rack-1",
    "mock": "node mock/server.js --type M56s -p 8080 -h 0.0.0.0"
  },
  "dependencies": {
    "@bitfinex/bfx-svc-boot-js": "1.2.0",
    "@tetherto/miningos-lib-stats": "git+https://github.com/tetherto/miningos-lib-stats.git",
    "@tetherto/miningos-tpl-wrk-miner": "git+https://github.com/tetherto/miningos-tpl-wrk-miner.git",
    "@tetherto/svc-facs-tcp": "git+https://github.com/tetherto/svc-facs-tcp.git#v1.0.0",
    "async": "3.2.6",
    "crypto-js": "4.2.0",
    "debug": "4.4.1"
  },
  "devDependencies": {
    "@bitfinex/lib-js-util-base": "git+https://github.com/bitfinexcom/lib-js-util-base.git",
    "@bitfinex/lib-js-util-promise": "git+https://github.com/bitfinexcom/lib-js-util-promise.git",
    "brittle": "3.16.3",
    "@tetherto/miningos-mock-control-service": "git+https://github.com/tetherto/miningos-mock-control-service.git",
    "standard": "17.1.2",
    "yargs": "17.7.2"
  }
}
